<%
  column_two_thirds ||= false
  margin_bottom ||= 0

  column_classes = %w[]
  column_classes << (column_two_thirds ? "govuk-grid-column-full" : "govuk-grid-column-two-thirds")

  column_classes << "govuk-!-margin-bottom-#{margin_bottom}" if !margin_bottom.zero?

%>

<div class="browse__breadcrumb-wrapper">
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="<%= column_classes.join(' ') %>">
        <%= render "application/breadcrumbs" %>
      </div>
    </div>
  </div>
</div>
