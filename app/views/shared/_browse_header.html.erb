<%
  two_thirds ||= false
  margin_bottom ||= 0
  padding_top ||= false

  header_wrapper_classes = %w"(govuk-!-margin-bottom-#{margin_bottom})" if !margin_bottom.zero?

  header_wrapper_classes << "govuk-!-padding-top-#{padding_top}" if padding_top.is_a? Numeric

  column_classes = %w()
  column_classes << (two_thirds ? "govuk-grid-column-two-thirds" : "govuk-grid-column-full")
%>

<div class="<%= header_wrapper_classes.join(' ') %>">
<%= render "govuk_publishing_components/components/inverse_header", {
  full_width: true
} do %>
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="<%= column_classes.join(' ') %>">
        <%= yield %>
      </div>
    </div>
  </div>
<% end %>
</div>
